ASPNETCORE_ENVIRONMENT=Development
# Render sets PORT automatically. ASPNETCORE_URLS is only needed for local runs.
ASPNETCORE_URLS=http://localhost:5000

ConnectionStrings__DefaultConnection=Host=YOUR_SUPABASE_POOLER_HOST;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DATABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

Jwt__Key=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=LeoEducation
Jwt__ExpiryMinutes=1440

Cors__AllowedOrigins=http://localhost:3000;http://localhost:3001;http://localhost:5173
Swagger__Enabled=true
Database__AutoMigrate=false
